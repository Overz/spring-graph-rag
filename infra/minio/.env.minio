# Par único de credenciais do object storage — fonte da verdade para MinIO e JuiceFS ([0.5]).
# Credenciais de DEV local; não usar em qualquer ambiente real.
MINIO_ROOT_USER=miniouser
MINIO_ROOT_PASSWORD=miniopass

# O JuiceFS lê as credenciais do storage destas variáveis (mesmos valores acima —
# env_file não suporta interpolação, por isso a repetição literal).
ACCESS_KEY=miniouser
SECRET_KEY=miniopass
